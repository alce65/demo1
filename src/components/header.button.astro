<div class="header-button">
    <slot  name="before"/>
    <slot />
    <slot  name="after" />
</div>

<style>
  .header-button {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin: 0.5rem;
    padding: .5rem;
    color: white;
    font-size: 1.5rem;
    cursor: pointer;
    border-radius: 10px;
    border: 1px solid white;

    &:hover {
      transform: scale(1.1);
    }
  }