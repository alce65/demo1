---
import Layout from '../layouts/layout.astro';
import { fetchRumDrinks } from '../services/api.repo';
import DrinkCard from '../components/drink.card.astro';
import type { Drink } from '../types';

const headerTitle = 'Inicio';
const headerDescription = 'Learn the basics of Astro';

const pageTitle: string = 'Inicio';
const pageSubTitle: string = 'Página de inicio';

let data: Drink[] = [];
try {
    data = await fetchRumDrinks();
} catch (error) {
    console.error(error);
}
---

<Layout title={headerTitle} description={headerDescription}>
    <section class="hero">
        <hgroup>
            <h2>{pageTitle}</h2>
            <p>{pageSubTitle}</p>
        </hgroup>
    </section>
    <section class="drinks">
        <h3>Rum Drinks</h3>
        <ul class="drinks-list">
            {data.map((drink) => <DrinkCard drink={drink} mode="static" />)}
        </ul>
        {
            data.length === 0 && (
                <p class="empty-state">No se pudieron cargar los drinks.</p>
            )
        }
    </section>
</Layout>

<style>
    h2 {
        color: red;
    }
    .drinks {
        ul {
            list-style: none;
            display: grid;
            gap: 1rem;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            grid-template-rows: repeat(4, auto);
        }
    }
    .empty-state {
        margin-top: 1rem;
    }
</style>

<script>
    console.log('Hello, Astro!');
</script>
