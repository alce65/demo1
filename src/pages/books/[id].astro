---
import Layout from '../../layouts/layout.astro';
import BookScore from '../../components/book.score.astro';
import { getCollection, render } from 'astro:content';
import { SHOW_BUY_BUTTON } from 'astro:env/server';
import type { Book } from '../../content/config';

const { id } = Astro.params;
if (!id) {
    return;
}

export const getStaticPaths = async () => {
    const books = await getCollection('books');

    console.log(books);
    const paths = books.map((book) => ({
        params: {
            id: book.slug,
        },
        props: {
            book: book,
        },
    }));
    return paths;
};

const { book } = Astro.props;
const data: Book = book.data;
const { Content } = await render(book);

// export const prerender = true
---

<Layout title={'Book' + id} description="Learn the basics of Astro">
    <article>
        <hgroup>
            <h3>{data.title}</h3>
            <p>{data.author}</p>
        </hgroup>
        <figure>
            <img src={'/books/' + data.img} alt={data.title} />
            <figcaption>{data.description}</figcaption>
        </figure>
        <div class="content">
            <Content />
        </div>
        <!-- <p class="score"></p> -->

        <dl>
            <dt>Tiempo de lectura</dt>
            <dd>{data.readtime}</dd>

            <BookScore server:defer>
                <dt class="score-fallback" slot="fallback">
                    Cargando puntuación...
                </dt>
            </BookScore>
        </dl>
        {SHOW_BUY_BUTTON && <button>Comprar</button>}
        {
            !SHOW_BUY_BUTTON && (
                <button class="no-valid" disabled>
                    Venta no disponible
                </button>
            )
        }
    </article>
</Layout>

<style>
    article {
        padding: 1rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        column-gap: 1.5rem;

        hgroup {
            grid-column: span 2;

            p {
                color: var(--color-secondary);
            }
        }
        figure {
            margin: 0;
            img {
                max-width: 100%;
            }
            figcaption {
                font-size: 0.9rem;
                color: var(--color-secondary);
            }
        }

        .content {
            grid-column: 2/3;
            grid-row: 2/4;

            p {
                margin-block-start: 0;
            }
        }

        p {
            color: #333;
        }

        dl {
            color: #333;
            display: grid;
            grid-template-columns: 2fr 1fr;

            .score-fallback {
                opacity: 0.5;
                font-size: 0.9rem;
            }
        }

        button {
            background-color: var(--color-secondary);
            color: white;
            padding: 0.5rem 1rem;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;

            &.no-valid {
                background-color: #ccc;
                cursor: inherit;
            }
        }
    }
</style>

